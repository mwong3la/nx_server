# Database (Postgres)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

NODE_ENV=development

# Auth (use a strong secret in production)
JWT_SECRET=

# Optional: report PDF uploads
AZURE_STORAGE_CONTAINER_NAME=
AZURE_STORAGE_CONNECTION_STRING=

# Seed users (optional, for local dev)
SEED_ADMIN_EMAIL=admin@coltium-auto.com
SEED_TECH_EMAIL=tech@coltium-auto.com
SEED_DEFAULT_PASSWORD=Coltium123!

# M-Pesa (required for subscription payments)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BUSINESS_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
# e.g. https://your-api.com/api/v1/payments/mpesa/callback
# Sandbox: https://sandbox.safaricom.co.ke (set MPESA_ENVIRONMENT=sandbox or omit for production)

# UI: set NEXT_PUBLIC_API_URL in the ui app (e.g. http://localhost:4000/api/v1)

# Contact form (Gmail). npm install includes nodemailer.
# Use a Google App Password (not your normal Gmail password): https://support.google.com/accounts/answer/185833
# CONTACT_EMAIL = Gmail account used to send (From). CONTACT_TO_EMAIL = where inquiries arrive (To); must differ.
CONTACT_EMAIL=
CONTACT_APP_PASSWORD=
CONTACT_TO_EMAIL=
# Logo for contact emails: local file only (embedded in the message, no fetch from your site).
# Put logo.png in backend/assets/ or set CONTACT_LOGO_PATH=/absolute/path/to/logo.png
CONTACT_LOGO_PATH=
#
# Legacy: custom SMTP if Gmail vars are not set — CONTACT_TO_EMAIL, SMTP_HOST, SMTP_USER, SMTP_PASS
# (optional: SMTP_PORT, SMTP_SECURE, SMTP_FROM)
