# Database (Postgres)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

NODE_ENV=development

# Auth (use a strong secret in production)
JWT_SECRET=

# Optional: report PDF uploads
AZURE_STORAGE_CONTAINER_NAME=
AZURE_STORAGE_CONNECTION_STRING=

# M-Pesa (required for subscription payments)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BUSINESS_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
# e.g. https://your-api.com/api/v1/payments/mpesa/callback
# Sandbox: https://sandbox.safaricom.co.ke (set MPESA_ENVIRONMENT=sandbox or omit for production)

# UI: set NEXT_PUBLIC_API_URL in the ui app (e.g. http://localhost:4000/api/v1)
